{
  "name": "omp-pi-hub-mobile-server",
  "version": "2.1.0",
  "description": "Extension and Flutter app for monitoring and controlling Pi and Oh-My-Pi agent sessions from a phone over any network.",
  "keywords": [
    "pi-package",
    "omp-package",
    "pi-coding-agent",
    "oh-my-pi",
    "omp-coding-agent",
    "dashboard",
    "flutter",
    "android",
    "agent-monitoring"
  ],
  "main": "omp-hub.ts",
  "files": [
    "hub-core.ts",
    "hub-server.mjs",
    "omp-hub.ts",
    "omp-hub-server.mjs",
    "pi-hub.ts",
    "pi-hub-server.mjs",
    "README.md",
    "LICENSE",
    "apps/hub_server_app/lib/**",
    "apps/hub_server_app/pubspec.yaml",
    "apps/hub_server_app/pubspec.lock",
    "apps/hub_server_app/analysis_options.yaml",
    "apps/hub_server_app/test/**",
    "apps/hub_server_app/android/**"
  ],
  "omp": {
    "extensions": [
      "./omp-hub.ts"
    ]
  },
  "pi": {
    "extensions": [
      "./pi-hub.ts"
    ]
  },
  "scripts": {
    "hub:server": "node hub-server.mjs"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/md-riaz/omp-pi-hub-mobile-server.git"
  }
}
